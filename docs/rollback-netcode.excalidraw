    {
      "type": "text",
      "id": "server_desc",
      "x": 460,
      "y": 158,
      "width": 280,
      "height": 50,
      "text": "Pure relay — no game logic\nRoutes: input, sync, round_event, ping/pong\nBroadcasts to spectators",
      "originalText": "Pure relay — no game logic\nRoutes: input, sync, round_event, ping/pong\nBroadcasts to spectators",
      "fontSize": 11,
      "fontFamily": 3,
