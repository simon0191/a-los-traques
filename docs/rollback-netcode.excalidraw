    {
      "type": "text",
      "id": "p1_steps",
      "x": 60,
      "y": 235,
      "width": 300,
      "height": 140,
      "text": "1. fighter.update() — FP gravity, frame timers\n2. applyInput() — FP velocities, attacks\n3. resolveBodyCollision() — FP coords\n4. faceOpponent() — simX comparison\n5. checkHit() — fpRectsOverlap()\n6. tickTimer() — frame-counted\n7. syncSprite() — render only",
      "originalText": "1. fighter.update() — FP gravity, frame timers\n2. applyInput() — FP velocities, attacks\n3. resolveBodyCollision() — FP coords\n4. faceOpponent() — simX comparison\n5. checkHit() — fpRectsOverlap()\n6. tickTimer() — frame-counted\n7. syncSprite() — render only",
