    {
      "type": "text",
      "id": "trust_host_text",
      "x": 90,
      "y": 165,
      "width": 240,
      "height": 180,
      "text": "HOST (P1 / Slot 0)\nTRUSTED\n\nRuns combat.checkHit()\nSends sync every 3 frames\nDetermines round outcomes\nApplies potion buffs\nHP/SP/stamina/timer\nare authoritative",
