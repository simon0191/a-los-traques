    {
      "type": "text",
      "id": "route_code_text",
      "x": 90,
      "y": 635,
      "width": 500,
      "height": 75,
      "text": "_sendToOther(slot, msg)   // Only opponent receives (not sender)\n_sendToHost(msg)          // Only slot 0 receives (potion requests)\n_broadcastToSpectators()  // Only spectators (not players)\n_broadcast()              // Everyone (for state updates)\n\nSpectator slot check: if (slot === -1) return;  // Block all player msgs",
