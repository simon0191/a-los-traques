{
  "private": true,
  "name": "a-los-traques",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter='@alostraques/web' run dev",
    "dev:db": "node scripts/dev-db.js",
    "dev:all": "concurrently \"node scripts/dev-db.js\" \"bun --filter='@alostraques/web' run dev\"",
    "dev:mp": "node scripts/dev-multiplayer.js",
    "build": "bun --filter='@alostraques/web' run build",
    "start": "bun --filter='@alostraques/web' run start",
    "party:dev": "bun --filter='@alostraques/party' run dev",
    "party:deploy": "bun --filter='@alostraques/party' run deploy",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.js",
    "test:e2e:headed": "playwright test --config tests/e2e/playwright.config.js --headed",
    "test:e2e:remote": "playwright test --config tests/e2e/remote/remote-playwright.config.js",
    "test:e2e:hybrid": "playwright test --config tests/e2e/remote/remote-playwright.config.js hybrid-multiplayer",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "balance": "bun run scripts/balance-sim/run.js",
    "migrate": "bash scripts/migrate.sh"
  },
  "dependencies": {
    "@alostraques/api-core": "workspace:*",
    "@alostraques/db": "workspace:*",
    "@alostraques/sim": "workspace:*",
    "pg": "^8.20.0",
    "partykit": "^0.0.115"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@electric-sql/pglite": "^0.4.2",
    "@electric-sql/pglite-socket": "^0.1.2",
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1",
    "turbo": "^2.9.6",
    "vitest": "^4.1.0"
  }
}
