{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "files": {
    "includes": [
      "apps/**",
      "packages/**",
      "api/**",
      "tests/**",
      "scripts/**",
      "*.json",
      "*.js",
      "!**/node_modules",
      "!**/dist",
      "!**/*.html",
      "!apps/game-vite/public",
      "!scripts/asset-pipeline/pose/.venv",
      "!scripts/asset-pipeline/pose/models",
      "!scripts/asset-pipeline/pose/__pycache__"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true
  }
}
